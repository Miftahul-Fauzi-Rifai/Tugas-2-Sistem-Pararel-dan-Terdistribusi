# Node Configuration
NODE_ID=node1
NODE_HOST=127.0.0.1
NODE_PORT=8001
PEERS=http://127.0.0.1:8002,http://127.0.0.1:8003

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/node.log

# System Configuration
HEARTBEAT_INTERVAL=1.0
ELECTION_TIMEOUT_MIN=2
ELECTION_TIMEOUT_MAX=4
SYNC_TIMEOUT=5.0

# Performance Tuning
BATCH_SIZE=100
MAX_CONNECTIONS=1000
QUEUE_SIZE=10000
CACHE_MAX_SIZE=1000
LRU_CACHE_SIZE=500

# Feature Flags
ENABLE_METRICS=true
ENABLE_DEADLOCK_DETECTION=true
DEBUG_MODE=false
